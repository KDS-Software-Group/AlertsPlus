<Window x:Class="AlertsPlus.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="300" Height="200"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.8"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0"
                             Duration="0:0:0.8"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="Root" Background="#121214" CornerRadius="16"
            BorderBrush="#2d2d30" BorderThickness="1" Opacity="0">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Image Source="/KDS.png"
                           Height="64" Width="64"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <Border Width="1" Background="#2d2d30" Margin="24,8"/>

                    <Image Source="/alertspluslogo.ico"
                           Height="64" Width="64"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                </StackPanel>

                <TextBlock Text="AlertsPlus"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,4"/>

                <!-- Subtitle -->
                <TextBlock Text="by KDS Software Group"
                           Foreground="#505050"
                           FontSize="12"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>