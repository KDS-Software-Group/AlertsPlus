<Window x:Class="AlertPlus.MainContentArea"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlertPlus"
        mc:Ignorable="d"
        Title="AlertPlus" Height="450" Width="800"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Icon="alertspluslogo.ico">
    <Window.Resources>
        <Style x:Key="MacButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Margin="10,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2d2d30"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3b82f6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#121214" CornerRadius="12" BorderBrush="#2d2d30" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarBorder" Grid.Column="0" Background="#1a1a1c" CornerRadius="12,0,0,12">
                <StackPanel>
                    <Canvas Height="50"/>
                    <Button Content="Scheduler" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Scheduler"/>
                    <Button Content="Temperature Watch" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Temp"/>
                    <Button Content="Settings" Style="{StaticResource SidebarButtonStyle}" Click="Nav_Click" Tag="Settings"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TitleText" Text="AlertPlus"
                       Grid.Column="1"
                       Foreground="#606060"
                       FontSize="11"
                       FontWeight="Medium"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,15,0,0"
                       IsHitTestVisible="False"/>

                <ContentControl x:Name="MainContentFrame" Grid.Row="1" Margin="10,0,10,10"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="15,15,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                <Button x:Name="BtnClose" Click="BtnClose_Click" Style="{StaticResource MacButtonStyle}" Background="#FF5F57"/>
                <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Style="{StaticResource MacButtonStyle}" Background="#FFBD2E" Margin="8,0,0,0"/>
                <Button x:Name="BtnMaximize" Click="BtnMaximize_Click" Style="{StaticResource MacButtonStyle}" Background="#28C840" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>