<UserControl x:Class="AlertPlus.ViewTempWatch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AlertPlus"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1a1a1c"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#2d2d30"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" SnapsToDevicePixels="true">
                            <Grid.Resources>
                                <Style x:Key="InvisibleRepeatButton" TargetType="RepeatButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Style="{StaticResource InvisibleRepeatButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Style="{StaticResource InvisibleRepeatButton}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444447" CornerRadius="4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="#66666a" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MacSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="Root" Cursor="Hand" Background="Transparent" Width="44" Height="24">
                            <Border x:Name="Track" 
                                    Width="44" Height="24" 
                                    CornerRadius="12" 
                                    Background="#3e3e42" />

                            <Border x:Name="Thumb" 
                                    Width="18" Height="18" 
                                    CornerRadius="9" 
                                    Background="White" 
                                    HorizontalAlignment="Left" 
                                    VerticalAlignment="Center"
                                    Margin="3,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="20" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="Track" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="#3b82f6" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="0" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="Track" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="#3e3e42" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="139*"/>
            <ColumnDefinition Width="621*"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Grid.ColumnSpan="2">
            <StackPanel Margin="0,-10,0,10">
                <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="Enable Temperature Monitoring" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Causes a notification to occur when temperatures become abnormal." Foreground="#808080" FontSize="12"/>
                        </StackPanel>
                        <CheckBox x:Name="MasterToggle" Style="{StaticResource MacSwitchStyle}" IsChecked="True" HorizontalAlignment="Right" Checked="SettingChanged" Unchecked="SettingChanged"/>
                    </DockPanel>
                </Border>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=MasterToggle, Path=IsChecked}" Value="False">
                                    <Setter Property="Opacity" Value="0.3"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="Current Readings" Foreground="White" FontSize="14" Margin="0,10,0,10" FontWeight="SemiBold"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Alert Configuration" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                            <DockPanel Margin="0,0,0,10">
                                <StackPanel Margin="0,0,0,4">
                                    <TextBlock Text="Temperature Threshold (°C)" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="Send notification when temp exceeds this limit" Foreground="#808080" FontSize="11"/>
                                </StackPanel>
                                <TextBox x:Name="ThresholdInput" Text="75" Width="60" Height="32" 
                                         HorizontalAlignment="Right" VerticalAlignment="Center"
                                         Background="#2d2d30" Foreground="White" BorderThickness="1" 
                                         BorderBrush="#3e3e42" VerticalContentAlignment="Center" 
                                         HorizontalContentAlignment="Center" Padding="2" TextChanged="ThresholdInput_TextChanged"/>
                            </DockPanel>

                            <Separator Background="#2d2d30" Margin="0,0,0,2"/>

                            <DockPanel Margin="0,0,0,10" Height="36">
                                <TextBlock Text="Monitor CPU" Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                                <CheckBox x:Name="MonitorCpuToggle" Style="{StaticResource MacSwitchStyle}" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            </DockPanel>

                            <DockPanel Margin="0,0,0,10" Height="36">
                                <TextBlock Text="Monitor GPU" Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                                <CheckBox x:Name="MonitorGpuToggle" Style="{StaticResource MacSwitchStyle}" IsChecked="True" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="SettingChanged" Unchecked="SettingChanged"/>
                            </DockPanel>

                            <DockPanel Margin="0,0,0,10" Height="36">
                                <DockPanel.Style>
                                    <Style TargetType="{x:Type DockPanel}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=MonitorGpuToggle}" Value="False">
                                                <Setter Property="Opacity" Value="0.3"/>
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DockPanel.Style>
                                <TextBlock Text="Monitor Hotspot (GPU)" Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                                <CheckBox x:Name="HotspotToggle" 
                                          Style="{StaticResource MacSwitchStyle}" 
                                          IsChecked="False" 
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Checked="SettingChanged" 
                                          Unchecked="SettingChanged"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <UniformGrid Columns="2" Margin="0,11,0,0">
                        <Border Margin="0,0,10,10" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="CPU" Foreground="#808080" FontSize="12"/>
                                        <TextBlock x:Name="CpuTempText" Text="--°C" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="Live Trend" VerticalAlignment="Bottom" HorizontalAlignment="Right" Foreground="#404040" FontSize="10"/>
                                </DockPanel>

                                <Expander IsExpanded="True" Header="History" Foreground="#606060" FontSize="10" BorderThickness="0">
                                    <Grid Height="80" Margin="0,5,0,0">
                                        <Rectangle Fill="#302020" Height="1" VerticalAlignment="Top" Margin="0,20,0,0"/>
                                        <TextBlock Text="90°C" Foreground="#604040" FontSize="9" VerticalAlignment="Top" Margin="0,15,5,0" HorizontalAlignment="Right"/>
                                        <Rectangle Fill="#252525" Height="1" VerticalAlignment="Top" Margin="0,60,0,0"/>
                                        <TextBlock Text="70°C" Foreground="#404040" FontSize="9" VerticalAlignment="Top" Margin="0,55,5,0" HorizontalAlignment="Right"/>
                                        <Rectangle Fill="#252525" Width="1" HorizontalAlignment="Right" Margin="0,0,2,0"/>
                                        <Polyline x:Name="CpuGraphLine" Stroke="#00CC7A" StrokeThickness="2" StrokeLineJoin="Round"/>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Margin="10,0,0,10" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="GPU" Foreground="#808080" FontSize="12"/>
                                        <TextBlock x:Name="GpuTempText" Text="--°C" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBlock Text="Live Trend" VerticalAlignment="Bottom" HorizontalAlignment="Right" Foreground="#404040" FontSize="10"/>
                                </DockPanel>

                                <Expander IsExpanded="True" Header="History" Foreground="#606060" FontSize="10" BorderThickness="0">
                                    <Grid Height="80" Margin="0,5,0,0">
                                        <Rectangle Fill="#302020" Height="1" VerticalAlignment="Top" Margin="0,20,0,0"/>
                                        <TextBlock Text="90°C" Foreground="#604040" FontSize="9" VerticalAlignment="Top" Margin="0,15,5,0" HorizontalAlignment="Right"/>
                                        <Rectangle Fill="#252525" Height="1" VerticalAlignment="Top" Margin="0,60,0,0"/>
                                        <TextBlock Text="70°C" Foreground="#404040" FontSize="9" VerticalAlignment="Top" Margin="0,55,5,0" HorizontalAlignment="Right"/>
                                        <Rectangle Fill="#252525" Width="1" HorizontalAlignment="Right" Margin="0,0,2,0"/>
                                        <Polyline x:Name="GpuGraphLine" Stroke="#007ACC" StrokeThickness="2" StrokeLineJoin="Round"/>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>