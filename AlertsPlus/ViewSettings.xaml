<UserControl x:Class="AlertPlus.ViewSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AlertPlus"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">

    <UserControl.Resources>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#505050"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="#1a1a1c"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="SettingsRow" TargetType="Border">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RowSubLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#505050"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="StyledRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="18" Height="18" VerticalAlignment="Center">
                                <Ellipse x:Name="Outer" Stroke="#404040" StrokeThickness="1.5" Fill="Transparent"/>
                                <Ellipse x:Name="Inner" Width="8" Height="8" Fill="#3b82f6" Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Outer" Property="Stroke" Value="#3b82f6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#3b82f6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background" Value="#3b82f6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2563eb"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1d4ed8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StyledToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="36" Height="20" CornerRadius="10"
                        Background="#333335" VerticalAlignment="Center">
                            <Ellipse x:Name="Thumb" Width="14" Height="14"
                             Fill="White" HorizontalAlignment="Left"
                             Margin="3,0,0,0" VerticalAlignment="Center">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#3b82f6"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                     Storyboard.TargetProperty="X"
                                                     To="16" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                     Storyboard.TargetProperty="X"
                                                     To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="24,20">
        <StackPanel>

            <TextBlock Text="Settings" Foreground="White" FontSize="18"
                       FontWeight="SemiBold" Margin="0,0,0,24"/>

            <!-- APPEARANCE -->
            <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>

                    <!-- Title Bar -->
                    <Border Style="{StaticResource SettingsRow}" CornerRadius="8,8,0,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Title Bar Style" Style="{StaticResource RowLabel}"/>
                                <TextBlock Text="Restart required to apply" Style="{StaticResource RowSubLabel}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <RadioButton x:Name="MacOsStyle" Content="macOS" GroupName="TitleBarStyle"
                                             Style="{StaticResource StyledRadio}" Margin="0,0,16,0"/>
                                <RadioButton x:Name="WindowsStyle" Content="Windows" GroupName="TitleBarStyle"
                                             Style="{StaticResource StyledRadio}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Rectangle Height="1" Fill="#242426" Margin="14,0"/>

                    <!-- Light Mode -->
                    <Border Style="{StaticResource SettingsRow}" CornerRadius="0,0,8,8" Opacity="0.4">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Light Mode" Foreground="#606060" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Feature coming soon!" Foreground="#404040" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="#2a2a2c" CornerRadius="6" Padding="10,4">
                                <TextBlock Text="Coming Soon" Foreground="#505050" FontSize="11"/>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>
            </Border>

            <!-- STARTUP -->
            <TextBlock Text="STARTUP" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRow}" CornerRadius="8">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Launch on Startup" Style="{StaticResource RowLabel}"/>
                                <TextBlock Text="Start AlertsPlus automatically when Windows starts"
                               Style="{StaticResource RowSubLabel}"/>
                            </StackPanel>
                            <CheckBox x:Name="AutoLaunchToggle" HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Style="{StaticResource StyledToggle}"
                          Checked="AutoLaunch_Changed"
                          Unchecked="AutoLaunch_Changed"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- NOTIFICATIONS -->
            <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionHeader}"/>
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <Border Style="{StaticResource SettingsRow}" CornerRadius="8">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Notification Position" Style="{StaticResource RowLabel}"/>
                                <TextBlock Text="Where alerts appear on screen" Style="{StaticResource RowSubLabel}"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <RadioButton x:Name="PosTopLeft" Content="Top Left" GroupName="NotifPosition"
                                                 Style="{StaticResource StyledRadio}" Margin="0,0,16,0"/>
                                    <RadioButton x:Name="PosTopRight" Content="Top Right" GroupName="NotifPosition"
                                                 Style="{StaticResource StyledRadio}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="PosBottomLeft" Content="Bottom Left" GroupName="NotifPosition"
                                                 Style="{StaticResource StyledRadio}" Margin="0,0,16,0"/>
                                    <RadioButton x:Name="PosBottomRight" Content="Bottom Right" GroupName="NotifPosition"
                                                 Style="{StaticResource StyledRadio}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="     ©️ 2026 KDS Software Group" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="     Version 1.0.0     Released 5/21/2026" Style="{StaticResource SectionHeader}"/>
                </StackPanel>
            </Border>

            <!-- SAVE -->
            <Button x:Name="SaveBtn" Content="Save &amp; Restart" 
                    Style="{StaticResource SaveButton}"
                    HorizontalAlignment="Right"
                    Click="SaveBtn_Click"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>