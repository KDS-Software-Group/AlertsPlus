<Window x:Class="Noticore.NotificationTray"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotificationTray" 
        Height="450" Width="350"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        ShowInTaskbar="False" 
        Topmost="True"
        IsHitTestVisible="False">
    <ItemsControl x:Name="NotificationList">
        <!-- notifications injected here. lines below are to make it stackable list -->
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel VerticalAlignment="Bottom"></StackPanel>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>
</Window>
