<UserControl x:Class="Noticore.NotificationItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="100" Width="300">
    <!-- Look! No Title, No WindowStyle, No Transparency here anymore -->

    <Border CornerRadius="15" Background="#222222" BorderBrush="#444444" BorderThickness="1" IsHitTestVisible="True">
        <Grid>
            <Button Content="✕" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Background="Transparent" 
                    Foreground="Gray" 
                    BorderThickness="0" 
                    Margin="8,5"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>

            <StackPanel Margin="15" VerticalAlignment="Center">
                <TextBlock x:Name="TitleTxt" 
                           Text="Notification" 
                           Foreground="White" 
                           FontWeight="Bold" 
                           FontSize="14"/>
                <TextBlock x:Name="MessageTxt" 
                           Text="Placeholder" 
                           Foreground="Silver" 
                           FontSize="12" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>